# Sanity CMS Configuration
# Copiez ce fichier en .env.local et remplissez vos valeurs

# Récupérez ces valeurs sur https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=votre_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token pour les requêtes côté serveur (lecture privée)
# Créez-le dans : sanity.io/manage > votre projet > API > Tokens
SANITY_API_READ_TOKEN=votre_token_ici

# URL du site (pour les métadonnées)
NEXT_PUBLIC_SITE_URL=https://eamotors.tg
